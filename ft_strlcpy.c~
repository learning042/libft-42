#include <stddef.h>
size_t	ft_strlcpy(char *dst, const char *src, size_t dsize)
{
	while(dsize-- && *src != '\0')
		*(dst++) = *(src++);
	*dst = '\0';
	return(ft_strlen(src));
}
#include <stdio.h>
int	main(void)
{
	char	*src = "hello";
	char	dst[4];
	printf("%i %s", ft_strlcpy(dst, src, 4), dst);
}
	
